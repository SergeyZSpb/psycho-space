# Build artifacts
/bin/
/dist/
/psycho-space
*.exe

# Go
/vendor/
*.test
*.out
coverage.*

# Embedded SPA build output (generated by the web build, embedded at compile time).
# The dir is fully ignored except a tracked .gitkeep so `go:embed` compiles on a
# fresh clone; the Go SPA handler serves a built-in fallback page until the
# frontend is built into this dir (CI does that before `go build`).
/internal/web/dist/*
!/internal/web/dist/.gitkeep

# Frontend
/web/node_modules/
/web/dist/
/web/.vite/
npm-debug.log*
yarn-error.log*

# Local env / secrets — NEVER commit
.env
*.env
!*.env.example
/secrets/
*.pem
*.key
id_ed25519*
id_rsa*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
