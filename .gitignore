# Build artifacts
/bin/
/dist/
/psycho-space
*.exe

# Go
/vendor/
*.test
*.out
coverage.*

# Embedded SPA build output (generated by the web build, embedded at compile time).
# The build writes the real SPA here; we keep a tracked placeholder index.html so
# `go:embed` always compiles even on a fresh clone that hasn't built the frontend.
/internal/web/dist/*
!/internal/web/dist/index.html

# Frontend
/web/node_modules/
/web/dist/
/web/.vite/
npm-debug.log*
yarn-error.log*

# Local env / secrets — NEVER commit
.env
*.env
!*.env.example
/secrets/
*.pem
*.key
id_ed25519*
id_rsa*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
