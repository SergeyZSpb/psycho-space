# Copy to .env for local runs (`./dev.sh run`). .env is gitignored — never commit real secrets.
# Generate keys with: openssl rand -base64 32
PSYCHOSPACE_ENV=dev
PSYCHOSPACE_HTTP_ADDR=127.0.0.1:8080
PSYCHOSPACE_BASE_URL=http://localhost:8080
PSYCHOSPACE_DATABASE_URL=postgres://psychospace:psychospace@127.0.0.1:5432/psychospace?sslmode=disable

PSYCHOSPACE_ENC_KEY=CHANGE_ME_base64_32_bytes
PSYCHOSPACE_HMAC_KEY=CHANGE_ME_base64_32_bytes
PSYCHOSPACE_SESSION_KEY=CHANGE_ME_base64_32_bytes

# VK ID (optional until P2). Leave blank to run without auth.
PSYCHOSPACE_VK_APP_ID=54691267
PSYCHOSPACE_VK_SERVICE_TOKEN=
PSYCHOSPACE_VK_REDIRECT_URI=http://localhost:8080/api/auth/vk/callback

# Optional id_token (OIDC) signature verification. Off by default; enable only
# after confirming VK's JWKS URL against the live app (else login is rejected).
PSYCHOSPACE_VK_VERIFY_IDTOKEN=false
PSYCHOSPACE_VK_JWKS_URL=
PSYCHOSPACE_VK_ISSUER=

# Game AI judge — OpenAI-compatible chat endpoint. Start target: YandexGPT 5
# Lite (Yandex Cloud Foundation Models). Set all three to enable the game;
# leave blank and /api/game/attempt returns 503. MODEL is the full model URI
# (folder-specific). Get an API key in the Yandex Cloud console.
PSYCHOSPACE_LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
PSYCHOSPACE_LLM_API_KEY=
PSYCHOSPACE_LLM_MODEL=gpt://<folder-id>/yandexgpt-5-lite

# Tracing export (off by default — trace IDs are still generated). e.g. localhost:4318
PSYCHOSPACE_OTLP_ENDPOINT=
